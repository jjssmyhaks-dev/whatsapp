{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["src/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"],
      "@webhook/*": ["src/webhook/*"],
      "@triage/*": ["src/triage/*"],
      "@templates/*": ["src/templates/*"],
      "@notifications/*": ["src/notifications/*"],
      "@threads/*": ["src/threads/*"],
      "@billing/*": ["src/billing/*"],
      "@auth/*": ["src/auth/*"]
    }
  }
}
