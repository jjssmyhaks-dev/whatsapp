# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=whatsapp_triage
DB_SSL=false
DB_SYNC=false
DB_LOGGING=true

# ============================================
# REDIS CONFIGURATION (for BullMQ)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# WHATSAPP CONFIGURATION
# ============================================
WHATSAPP_APP_SECRET=test_app_secret_1234567890abcdef
WHATSAPP_WEBHOOK_VERIFY_TOKEN=test_verify_token_12345
WHATSAPP_API_VERSION=v18.0

# ============================================
# ENCRYPTION CONFIGURATION
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=test_jwt_secret_key_1234567890abcdef
JWT_EXPIRES_IN=24h

# ============================================
# MISTRAL AI CONFIGURATION
# ============================================
MISTRAL_API_KEY=test_mistral_api_key

# ============================================
# ONESIGNAL CONFIGURATION
# ============================================
ONESIGNAL_APP_ID=test_onesignal_app_id
ONESIGNAL_API_KEY=test_onesignal_api_key
ONESIGNAL_TEST_PLAYER_ID=test_player_id

# ============================================
# RAZORPAY CONFIGURATION (Phase 3)
# ============================================
RAZORPAY_KEY_ID=test_razorpay_key
RAZORPAY_KEY_SECRET=test_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=test_razorpay_webhook_secret

# ============================================
# EMBEDDINGS CONFIGURATION
# ============================================
# Set to false to disable local embedding model
USE_LOCAL_EMBEDDINGS=true

# ============================================
# APPLICATION CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=debug
